server {
    listen 80;
    server_name social.vitrineiapro.com.br;

    location /.well-known/acme-challenge/ {
        root /usr/share/nginx/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name social.vitrineiapro.com.br;

    ssl_certificate /etc/letsencrypt/live/social.vitrineiapro.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/social.vitrineiapro.com.br/privkey.pem;

    client_max_body_size 32M;

    location / {
        proxy_pass http://studio_web:80;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 180;
    }
}
